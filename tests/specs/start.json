[
  {
    "name": "/start shows today's matches by league when no matches exist",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📅 No matches today!\n\nNo matches scheduled yet — check back soon!"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "menu:main callback returns to the main menu",
    "steps": [
      {
        "send": { "callback": "menu:main" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "👋 Welcome to Football Predictor! Tap a button below to get started." }
          }
        ]
      }
    ]
  },
  {
    "name": "today:show callback shows today's leagues",
    "steps": [
      {
        "send": { "callback": "today:show" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "📅 No matches today!\n\nNo matches scheduled yet — check back soon!"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "today:league:invalid shows not found",
    "steps": [
      {
        "send": { "callback": "today:league:nonexistent" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Couldn't find that league."
            }
          }
        ]
      }
    ]
  }
]
