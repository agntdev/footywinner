[
  {
    "name": "/start shows no matches today when schedule is empty",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📅 No matches today!"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "menu:main callback returns to the main menu",
    "steps": [
      {
        "send": { "callback": "menu:main" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "👋 Welcome to Football Predictor! Tap a button below to get started." }
          }
        ]
      }
    ]
  },
  {
    "name": "today:show callback shows today's matches when empty",
    "steps": [
      {
        "send": { "callback": "today:show" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "📅 No matches today!"
            }
          }
        ]
      }
    ]
  }
]
